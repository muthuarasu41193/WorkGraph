# Deploy as a Next.js app (Vercel/Node) or Docker (see docs/SETUP.md).
# Resume uploads are limited to ~4 MB on typical serverless hosts (see lib/upload-limits.ts).

# Self-hosted WorkGraph API (spaCy + Ollama — no Groq required when set)
WORKGRAPH_API_URL=http://localhost:8000
NEXT_PUBLIC_WORKGRAPH_API_URL=http://localhost:8000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=

# Full self-hosted template: .env.workgraph.example

# Apply supabase/migrations/20260202120000_jobs_board.sql so public.jobs + job_tracker_entries exist.
# Python job_aggregator: prefer DATABASE_HOST + DATABASE_PASSWORD in job_aggregator/.env (see job_aggregator/.env.example).
#
# Production live listings: on Vercel set NEXT_PUBLIC_SUPABASE_* to this project; add GitHub Actions secret
# JOBS_DATABASE_URL (or pooler secrets) per .github/workflows/supabase-jobs-ingest.yml, then enable the workflow on your repo.

# Hidden Jobs Discovery (/api/hidden-jobs) — Reddit, HN, GitHub only (ATS jobs use /api/jobs)
# GITHUB_TOKEN=ghp_...  # optional; raises GitHub Search API rate limits
# HIDDEN_REDDIT_SUBREDDITS=forhire,jobs,remotejobs
# REDDIT_USER_AGENT=windows:workgraph:1.0.0 (by /u/yourredditusername)
# HIDDEN_JOBS_CACHE_TTL_MS=1800000
# Apply supabase/migrations/20260601120000_hidden_jobs_discovery.sql for analytics persistence
