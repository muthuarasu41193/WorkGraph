# Sample layout — copy to job_aggregator/.env (never commit real passwords).

# Preferred: split vars (password may contain @ — no URL-encoding).
# DATABASE_HOST=db.<project-ref>.supabase.co
# DATABASE_PASSWORD=
# DATABASE_USER=postgres
# DATABASE_NAME=postgres
# DATABASE_PORT=5432

# Alternative: single URI — no space after "postgres:", encode @ in password as %40.
# DATABASE_URL=postgresql+psycopg2://postgres:ENCODED_PASSWORD@db.<project-ref>.supabase.co:5432/postgres

# If Windows reports "Name or service not known" for db.*.supabase.co, use the Session pooler
# connection string from Supabase (often IPv4-friendly): host *.pooler.supabase.com port 6543.
