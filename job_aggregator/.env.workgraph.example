# WorkGraph API / ingest — copy to job_aggregator/.env
#   Copy-Item .env.workgraph.example .env
# Full web + Docker vars also live at ../.env.workgraph.example

WORKGRAPH_ENV=development

# Self-hosted Postgres (Docker: docker compose … up -d postgres)
DATABASE_URL=postgresql+psycopg2://workgraph:workgraph_dev@localhost:5432/workgraph

# Or SQLite for quick local tests (no Docker DB):
# DATABASE_URL=sqlite:///./jobs.db

REDIS_URL=redis://localhost:6379/0
JOB_AGGREGATOR_API_KEY=change_me_ingest_secret
CRON_SECRET=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=workgraph
MINIO_SECRET_KEY=workgraph_minio_dev
MINIO_BUCKET_RESUMES=resumes

TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=workgraph_typesense_dev

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_BATCH_SIZE=32
MAX_RESUME_UPLOAD_BYTES=4194304

CORS_ORIGINS=http://localhost:3000
API_RATE_LIMIT=120/minute

# Legacy Supabase (optional — omit when using DATABASE_URL above)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Reddit ingest (PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=workgraph/1.0

# Typesense (optional — search falls back to SQL)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=workgraph_typesense_dev
TYPESENSE_COLLECTION=workgraph_jobs
