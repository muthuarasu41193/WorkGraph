# Copy to job_aggregator/.env — overrides repo-root .env.local / .env for this package.

# --- Recommended (IPv4 Session pooler on Windows; passwords may contain @) ---
# DATABASE_PASSWORD=your_database_password
# DATABASE_POOLER_REGION=us-east-1
# Discover region: python -m app.main probe-db
#
# Project ref defaults from NEXT_PUBLIC_SUPABASE_URL in ../.env.local or set explicitly:
# SUPABASE_PROJECT_REF=your_project_ref

# Optional explicit pooler / direct host (skips shorthand):
# DATABASE_HOST=aws-0-<REGION>.pooler.supabase.com
# DATABASE_USER=postgres.<project_ref>
# DATABASE_PORT=5432
# DATABASE_NAME=postgres

# Direct db host + IPv6 literal — only if your network has IPv6; bypass broken hostname DNS:
# DATABASE_HOST=db.<project-ref>.supabase.co
# DATABASE_HOSTADDR=<paste AAAA from nslookup>

# Aliases: SUPABASE_DB_* mirror DATABASE_*

# --- Single URI ---
# DATABASE_URL=postgresql+psycopg2://postgres:ENCODED@db.<ref>.supabase.co:5432/postgres

# --- SQLite ---
# Leave DB vars unset and omit DATABASE_URL to use ./jobs.db

# Optional overrides
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL_VERSION=all-MiniLM-L6-v2-v1
# COMPANIES_JSON=./companies.json
# HTTP_TIMEOUT_SECONDS=25
# HTTP_MAX_RETRIES=4
# EMBED_BATCH_SIZE=32
