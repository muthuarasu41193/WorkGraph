# =============================================================================
# WorkGraph — self-hosted environment (copy to .env and job_aggregator/.env)
# =============================================================================

WORKGRAPH_ENV=development

# --- Web (Next.js) ---
NEXT_PUBLIC_WORKGRAPH_API_URL=http://localhost:8000
WORKGRAPH_API_URL=http://localhost:8000

# Legacy Supabase (optional during migration — remove when fully self-hosted)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- PostgreSQL (Docker default) ---
POSTGRES_PASSWORD=workgraph_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://workgraph:workgraph_dev@localhost:5432/workgraph

# --- Redis / queues ---
REDIS_URL=redis://localhost:6379/0
WORKER_CRON_ENABLED=false
WORKER_SCRAPE_INTERVAL_MS=3600000
JOB_AGGREGATOR_API_KEY=change_me_ingest_secret

# --- MinIO ---
MINIO_ROOT_USER=workgraph
MINIO_ROOT_PASSWORD=workgraph_minio_dev
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=workgraph
MINIO_SECRET_KEY=workgraph_minio_dev
MINIO_BUCKET_RESUMES=resumes

# --- Typesense ---
TYPESENSE_API_KEY=workgraph_typesense_dev
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108

# --- Ollama (local LLM — no paid APIs) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# --- ML ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_BATCH_SIZE=32
MAX_RESUME_UPLOAD_BYTES=4194304

# --- API security ---
CORS_ORIGINS=http://localhost:3000
API_RATE_LIMIT=120/minute
CRON_SECRET=

# --- Auth (default: Supabase) ---
AUTH_PROVIDER=supabase
NEXT_PUBLIC_AUTH_PROVIDER=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Employer notifications (Resend — https://resend.com)
RESEND_API_KEY=
WORKGRAPH_EMAIL_FROM=WorkGraph <onboarding@resend.dev>
EMPLOYER_ADMIN_SECRET=
WORKGRAPH_COMMUNITY_AUTO_APPROVE=true

# Optional: SuperTokens self-hosted (only when Supabase keys are unset)
# AUTH_PROVIDER=supertokens
# NEXT_PUBLIC_AUTH_PROVIDER=supertokens
# SUPERTOKENS_CONNECTION_URI=http://localhost:3567
# SUPERTOKENS_API_KEY=

# --- Reddit ingest (PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=workgraph/1.0

# --- Optional payments (app works without) ---
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=workgraph

# --- n8n automation ---
N8N_USER=admin
N8N_PASSWORD=workgraph_n8n
